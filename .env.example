# Neon Postgres connection string. Do not commit a real value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/trusted_recs?sslmode=require"

# TMDB is used in later milestones and must only be read server-side.
TMDB_API_KEY="[placeholder]"
TMDB_BASE_URL="https://api.themoviedb.org/3"
TMDB_IMAGE_BASE_URL="https://image.tmdb.org/t/p"
DEFAULT_WATCH_REGION="GB"

# Google Books is used server-side for book search and details.
GOOGLE_BOOKS_API_KEY="[placeholder]"
GOOGLE_BOOKS_BASE_URL="https://www.googleapis.com/books/v1"

# Spotify is used server-side for album search and details.
SPOTIFY_CLIENT_ID="[placeholder]"
SPOTIFY_CLIENT_SECRET="[placeholder]"
SPOTIFY_BASE_URL="https://api.spotify.com/v1"
SPOTIFY_ACCOUNTS_URL="https://accounts.spotify.com"

# Local default; set to your stable Vercel production/custom-domain URL when deployed.
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"
